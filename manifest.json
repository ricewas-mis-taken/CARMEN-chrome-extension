{
  "manifest_version": 3,
  "name": "Focus Tracker",
  "version": "0.1.0",
  "description": "Tracks tab activity during focus sessions and flags off-topic tabs.",
  "permissions": ["tabs", "storage", "scripting", "alarms", "notifications", "offscreen"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:5847/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icon128.png"
  },
  "icons": {
    "128": "icon128.png"
  }
}
